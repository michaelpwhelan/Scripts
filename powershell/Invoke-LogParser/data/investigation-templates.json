        "levels": ["CRITICAL", "ERROR", "WARNING"],
        "formats": ["certificate-event"]
    },
    {
        "id": "compliance-violations",
        "name": "Compliance Violations",
        "category": "Compliance",
        "description": "Events indicating potential compliance control failures",
        "regex": "non-compliant|violation|policy.*fail|unauthorized|denied",
        "levels": ["CRITICAL", "ERROR", "WARNING"],
        "formats": ["intune-compliance", "windows-evtx", "fortigate-kv"]
    },
    {
        "id": "vulnerability-critical",
        "name": "Critical Vulnerabilities",
        "category": "Security",
