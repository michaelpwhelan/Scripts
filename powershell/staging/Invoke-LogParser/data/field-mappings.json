{
    "_description": "Maps virtual query fields to actual parser output field names",
    "virtualFields": {
        "user": {
            "entryFields": [],
            "extraFields": ["user", "User-Name", "SAM-Account-Name", "TargetUserName", "UserPrincipalName", "SubjectUserName", "Fully-Qualifed-User-Name", "InitiatedByUser"],
            "description": "Username across all log sources"
        },
        "srcip": {
            "entryFields": [],
            "extraFields": ["srcip", "IpAddress", "IPAddress", "Client-IP-Address", "Calling-Station-Id", "SourceAddress", "ClientIPAddress"],
            "description": "Source IP address"
        },
        "dstip": {
            "entryFields": [],
            "extraFields": ["dstip", "DestinationAddress", "NAS-IP-Address", "RemoteGw"],
            "description": "Destination IP address"
        },
        "action": {
            "entryFields": [],
            "extraFields": ["action", "Action", "PacketTypeName", "Result", "ComplianceState", "Status"],
            "description": "Action taken (allow/deny/block etc)"
        },
        "eventid": {
            "entryFields": [],
            "extraFields": ["EventID", "logid", "AlertId"],
            "description": "Event/log identifier"
        },
        "device": {
            "entryFields": ["Host"],
            "extraFields": ["devname", "DeviceName", "Computer-Name", "MachineName", "computerDnsName", "HostName"],
            "description": "Device or hostname"
        },
        "source": {
            "entryFields": ["Source"],
            "extraFields": ["SourceFormat", "ProviderName"],
            "description": "Log source or parser format"
        },
        "severity": {
            "entryFields": ["Level"],
            "extraFields": ["Severity", "VulnerabilitySeverity", "ZabbixSeverity"],
            "description": "Severity/level (maps high->ERROR, medium->WARNING, etc)"
        },
        "port": {
            "entryFields": [],
            "extraFields": ["dstport", "srcport", "PortName"],
            "description": "Port number or name"
        },
        "tunnel": {
            "entryFields": [],
            "extraFields": ["TunnelName", "tunnelid", "vpntunnel", "tunnelip"],
            "description": "VPN/IPsec tunnel identifier"
        },
        "policy": {
            "entryFields": [],
            "extraFields": ["policyid", "PolicyName", "policyname"],
            "description": "Firewall policy identifier"
        },
        "app": {
            "entryFields": [],
            "extraFields": ["AppDisplayName", "app", "appcat", "application"],
            "description": "Application name"
        },
        "url": {
            "entryFields": [],
            "extraFields": ["url", "hostname", "QueryName"],
            "description": "URL or hostname"
        },
        "mac": {
            "entryFields": [],
            "extraFields": ["MACAddress", "MacAddress", "Calling-Station-Id"],
            "description": "MAC address"
        },
        "vlan": {
            "entryFields": [],
            "extraFields": ["VlanId", "vlan"],
            "description": "VLAN identifier"
        }
    },
    "severityAliases": {
        "critical": ["CRITICAL"],
        "high": ["CRITICAL", "ERROR"],
        "medium": ["WARNING"],
        "low": ["INFO"],
        "info": ["INFO", "DEBUG", "TRACE"],
        "debug": ["DEBUG", "TRACE"]
    }
}
